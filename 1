<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yoga & Digital Detox — College Seminar</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --sage: #7a9e7e;
    --sage-light: #a8c5a0;
    --cream: #f7f3ed;
    --warm-white: #fdfaf6;
    --clay: #c4956a;
    --clay-light: #e8c9a8;
    --moss: #4a7355;
    --moss-dark: #2d4a35;
    --stone: #8c8577;
    --text: #2c2c2c;
    --text-light: #5a5a5a;
    --leaf: #5c8c4a;
  }

  html, body { width: 100%; height: 100%; overflow: hidden; background: var(--cream); }

  /* ── SLIDE CONTAINER ── */
  .deck { width: 100vw; height: 100vh; position: relative; overflow: hidden; }

  .slide {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    padding: 48px 64px;
    opacity: 0; pointer-events: none;
    transition: opacity 0.7s ease, transform 0.7s ease;
    transform: translateY(24px);
    background: var(--warm-white);
  }
  .slide.active { opacity: 1; pointer-events: all; transform: translateY(0); }
  .slide.exit   { opacity: 0; transform: translateY(-24px); }

  /* ── DECORATIVE BG LAYERS ── */
  .slide-bg {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 0;
  }
  .slide-bg .circle {
    position: absolute; border-radius: 50%;
    background: radial-gradient(circle, rgba(122,158,126,0.12) 0%, transparent 70%);
  }
  .slide-bg .leaf-line {
    position: absolute;
    width: 2px; background: rgba(122,158,126,0.15);
    transform-origin: bottom center;
  }

  /* ── LAYOUT HELPERS ── */
  .slide-inner { position: relative; z-index: 1; width: 100%; max-width: 1100px; }

  .slide-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; font-weight: 500; letter-spacing: 3px; text-transform: uppercase;
    color: var(--sage); margin-bottom: 18px;
  }

  h1.hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 6vw, 84px); font-weight: 300; line-height: 1.1;
    color: var(--moss-dark);
  }
  h1.hero-title em { font-style: italic; color: var(--clay); }

  h2.slide-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 4vw, 52px); font-weight: 400; line-height: 1.2;
    color: var(--moss-dark); margin-bottom: 28px;
  }
  h2.slide-title span { color: var(--clay); }

  h3.sub-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 600; color: var(--moss);
    margin: 20px 0 10px; font-style: italic;
  }

  p.intro-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px; color: var(--text-light); max-width: 520px; line-height: 1.7;
    margin-top: 12px;
  }

  .meta-line {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; color: var(--stone); letter-spacing: 1px;
    margin-top: 32px; display: flex; gap: 32px;
  }
  .meta-line span::before { content: '— '; }

  /* ── COLUMNS ── */
  .cols { display: grid; gap: 40px; align-items: start; width: 100%; }
  .cols-2 { grid-template-columns: 1fr 1fr; }
  .cols-3 { grid-template-columns: 1fr 1fr 1fr; }

  /* ── BULLET LIST ── */
  .bullet-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 8px; }
  .bullet-list li {
    font-family: 'DM Sans', sans-serif; font-size: 15px; color: var(--text);
    display: flex; align-items: flex-start; gap: 12px; line-height: 1.55;
    animation: fadeUp 0.5s ease both;
  }
  .bullet-list li .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--sage); flex-shrink: 0; margin-top: 6px;
  }
  .bullet-list li .dot.clay { background: var(--clay); }
  .bullet-list li .dot.moss { background: var(--moss); }

  .bullet-list li:nth-child(1) { animation-delay: 0.1s; }
  .bullet-list li:nth-child(2) { animation-delay: 0.2s; }
  .bullet-list li:nth-child(3) { animation-delay: 0.3s; }
  .bullet-list li:nth-child(4) { animation-delay: 0.4s; }
  .bullet-list li:nth-child(5) { animation-delay: 0.5s; }
  .bullet-list li:nth-child(6) { animation-delay: 0.6s; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── CARD ── */
  .card {
    background: #fff; border-radius: 18px; padding: 28px 24px;
    border: 1px solid rgba(122,158,126,0.2);
    box-shadow: 0 4px 24px rgba(45,74,53,0.06);
  }
  .card-icon { font-size: 32px; margin-bottom: 12px; }
  .card h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; color: var(--moss-dark); margin-bottom: 8px; font-weight: 600;
  }

  /* ── DIVIDER ── */
  .divider {
    width: 60px; height: 2px;
    background: linear-gradient(90deg, var(--clay), var(--sage-light));
    border-radius: 2px; margin: 16px 0 24px;
  }
  .divider.sm { width: 36px; margin: 10px 0 16px; }

  /* ── YOGA SVG ILLUSTRATIONS ── */
  .yoga-art { width: 100%; max-width: 220px; opacity: 0.85; }

  /* ── HIGHLIGHT BOX ── */
  .highlight-box {
    background: linear-gradient(135deg, rgba(122,158,126,0.1), rgba(196,149,106,0.08));
    border-left: 4px solid var(--sage);
    border-radius: 0 12px 12px 0;
    padding: 18px 22px; margin: 20px 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; font-style: italic; color: var(--moss-dark); line-height: 1.5;
  }

  /* ── STEP BOX ── */
  .step-row { display: flex; gap: 10px; margin-bottom: 9px; align-items: flex-start; }
  .step-num {
    width: 24px; height: 24px; border-radius: 50%;
    background: var(--sage); color: #fff;
    font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .step-text { font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--text); line-height: 1.5; }

  /* ── TAG ── */
  .tag {
    display: inline-block; padding: 4px 14px; border-radius: 20px;
    font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500; letter-spacing: 0.5px;
    background: rgba(122,158,126,0.12); color: var(--moss);
    margin: 4px 4px 4px 0;
  }
  .tag.clay { background: rgba(196,149,106,0.15); color: #8a5a30; }
  .tag.red  { background: rgba(200,80,80,0.12);   color: #8a2020; }

  /* ── CONCLUSION STATS ── */
  .stat-block { text-align: center; }
  .stat-block .big {
    font-family: 'Cormorant Garamond', serif;
    font-size: 52px; color: var(--moss); font-weight: 300; line-height: 1;
  }
  .stat-block .label {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; color: var(--stone); margin-top: 6px; letter-spacing: 0.5px;
  }

  /* ── NAV ── */
  .nav {
    position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 16px;
    background: rgba(255,255,255,0.85); backdrop-filter: blur(16px);
    border: 1px solid rgba(122,158,126,0.25);
    border-radius: 50px; padding: 10px 24px;
    box-shadow: 0 8px 32px rgba(45,74,53,0.12);
    z-index: 100;
  }
  .nav button {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--moss); border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, transform 0.15s;
    color: #fff; font-size: 16px;
  }
  .nav button:hover { background: var(--moss-dark); transform: scale(1.05); }
  .nav button:disabled { background: #ccc; cursor: default; transform: none; }
  .nav .slide-counter {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; color: var(--stone); min-width: 64px; text-align: center;
    letter-spacing: 1px;
  }
  .nav .dots { display: flex; gap: 6px; align-items: center; }
  .nav .dot-btn {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--clay-light); border: none; cursor: pointer;
    transition: background 0.2s, transform 0.2s; padding: 0;
  }
  .nav .dot-btn.on { background: var(--moss); transform: scale(1.3); }

  /* ── PROGRESS BAR ── */
  .progress-bar {
    position: fixed; top: 0; left: 0; height: 3px;
    background: linear-gradient(90deg, var(--sage), var(--clay));
    transition: width 0.5s ease; z-index: 200;
  }

  /* ── SLIDE NUMBER (corner) ── */
  .slide-num-badge {
    position: absolute; top: 28px; right: 32px;
    font-family: 'DM Sans', sans-serif; font-size: 11px; color: var(--stone);
    letter-spacing: 1px; z-index: 2;
  }

  /* ── LEAF DECORATION ── */
  .leaf-deco { position: absolute; opacity: 0.07; font-size: 180px; line-height: 1;
    pointer-events: none; user-select: none; }

  /* ── WARNING BOX ── */
  .warn-box {
    background: rgba(200,80,80,0.06); border-left: 4px solid #c85050;
    border-radius: 0 10px 10px 0; padding: 16px 20px;
    font-family: 'DM Sans', sans-serif; font-size: 14px; color: #6a2020; line-height: 1.6;
    margin-top: 12px;
  }

  /* ── TITLE SLIDE SPECIAL ── */
  #slide-1 { background: linear-gradient(155deg, #f0ece4 0%, #e8f0e4 50%, #f5ede5 100%); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .slide { padding: 28px 20px; }
    .cols-2, .cols-3 { grid-template-columns: 1fr; gap: 20px; }
    h1.hero-title { font-size: 38px; }
    h2.slide-title { font-size: 26px; }
  }
</style>
</head>
<body>

<div class="progress-bar" id="progressBar"></div>

<div class="deck" id="deck">

  <!-- ═══════════════ SLIDE 1 — TITLE ═══════════════ -->
  <div class="slide active" id="slide-1">
    <div class="slide-bg">
      <div class="circle" style="width:600px;height:600px;top:-150px;right:-150px;"></div>
      <div class="circle" style="width:400px;height:400px;bottom:-100px;left:-100px;"></div>
    </div>
    <div class="leaf-deco" style="right:-20px;bottom:-30px;">🌿</div>
    <div class="slide-num-badge">01 / 12</div>

    <div class="slide-inner" style="display:flex;align-items:center;gap:60px;flex-wrap:wrap;">
      <div style="flex:1;min-width:280px;">
        <div class="slide-label">College Seminar Presentation</div>
        <h1 class="hero-title">Yoga &<br><em>Digital Detox</em></h1>
        <div class="divider"></div>
        <p class="intro-text">
          A holistic approach to reclaiming mental clarity, inner peace, and a healthier relationship with technology.
        </p>
        <div class="meta-line">
          <span>Dept. of Health & Wellness</span>
          <span>April 2025</span>
        </div>
      </div>

      <div style="flex:0 0 260px;display:flex;justify-content:center;">
        <!-- Meditation SVG -->
        <svg viewBox="0 0 260 300" class="yoga-art" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="130" cy="285" rx="80" ry="8" fill="rgba(122,158,126,0.12)"/>
          <!-- Body -->
          <circle cx="130" cy="60" r="26" fill="#c4956a" opacity="0.85"/>
          <!-- Hair -->
          <ellipse cx="130" cy="46" rx="22" ry="10" fill="#5a4030" opacity="0.7"/>
          <!-- Torso -->
          <path d="M95 130 Q105 100 130 95 Q155 100 165 130 L160 190 Q130 200 100 190 Z" fill="#7a9e7e" opacity="0.7"/>
          <!-- Left arm -->
          <path d="M95 130 Q70 150 60 175" stroke="#c4956a" stroke-width="14" stroke-linecap="round" fill="none"/>
          <!-- Right arm -->
          <path d="M165 130 Q190 150 200 175" stroke="#c4956a" stroke-width="14" stroke-linecap="round" fill="none"/>
          <!-- Left hand resting -->
          <circle cx="60" cy="178" r="9" fill="#c4956a" opacity="0.85"/>
          <!-- Right hand resting -->
          <circle cx="200" cy="178" r="9" fill="#c4956a" opacity="0.85"/>
          <!-- Crossed legs -->
          <path d="M100 190 Q80 230 60 255 Q90 265 120 250 Q130 225 130 200" fill="#7a9e7e" opacity="0.65"/>
          <path d="M160 190 Q180 230 200 255 Q170 265 140 250 Q130 225 130 200" fill="#7a9e7e" opacity="0.65"/>
          <!-- Aura rings -->
          <circle cx="130" cy="130" r="110" fill="none" stroke="rgba(122,158,126,0.12)" stroke-width="2"/>
          <circle cx="130" cy="130" r="130" fill="none" stroke="rgba(196,149,106,0.08)" stroke-width="2"/>
          <!-- Om symbol -->
          <text x="120" y="148" font-size="24" fill="rgba(45,74,53,0.3)" font-family="serif">☯</text>
        </svg>
      </div>
    </div>
  </div>

  <!-- ═══════════════ SLIDE 2 — INTRODUCTION ═══════════════ -->
  <div class="slide" id="slide-2">
    <div class="slide-bg">
      <div class="circle" style="width:500px;height:500px;top:-200px;left:-100px;"></div>
    </div>
    <div class="leaf-deco" style="right:20px;top:20px;font-size:140px;opacity:0.06;">🍃</div>
    <div class="slide-num-badge">02 / 12</div>
    <div class="slide-inner">
      <div class="slide-label">Setting the Context</div>
      <h2 class="slide-title">Introduction</h2>
      <div class="divider"></div>

      <div class="cols cols-2">
        <div>
          <h3 class="sub-title">Technology in Modern Life</h3>
          <ul class="bullet-list">
            <li><span class="dot"></span>Over 5 billion people use the internet globally</li>
            <li><span class="dot"></span>Average screen time: 6–8 hours per day</li>
            <li><span class="dot"></span>Technology drives education, work & social life</li>
            <li><span class="dot"></span>Smartphones have become extensions of the self</li>
          </ul>
        </div>
        <div>
          <h3 class="sub-title">Why We Need a Change</h3>
          <ul class="bullet-list">
            <li><span class="dot clay"></span>Rising cases of digital addiction & anxiety</li>
            <li><span class="dot clay"></span>Sleep disorders linked to screen exposure</li>
            <li><span class="dot clay"></span>Loss of mindfulness and present-moment awareness</li>
            <li><span class="dot clay"></span>Yoga + Digital Detox = a natural solution</li>
          </ul>
        </div>
      </div>

      <div class="highlight-box" style="margin-top:28px;">
        "We are living in the most connected era in history — yet we have never felt more disconnected from ourselves."
      </div>
    </div>
  </div>

  <!-- ═══════════════ SLIDE 3 — MEANING OF DIGITAL DETOX ═══════════════ -->
  <div class="slide" id="slide-3">
    <div class="slide-bg">
      <div class="circle" style="width:450px;height:450px;bottom:-100px;right:-100px;"></div>
    </div>
    <div class="slide-num-badge">03 / 12</div>
    <div class="slide-inner">
      <div class="slide-label">Concept Overview</div>
      <h2 class="slide-title">What is <span>Digital Detox?</span></h2>
      <div class="divider"></div>

      <div class="cols cols-2" style="align-items:center;">
        <div>
          <div class="highlight-box">
            A period of time during which a person refrains from using electronic devices — to reduce stress and focus on real-world connections.
          </div>
          <h3 class="sub-title" style="margin-top:24px;">Purpose & Importance</h3>
          <ul class="bullet-list">
            <li><span class="dot moss"></span>Restore mental and emotional balance</li>
            <li><span class="dot moss"></span>Improve sleep quality and daily focus</li>
            <li><span class="dot moss"></span>Rebuild face-to-face human connections</li>
            <li><span class="dot moss"></span>Reduce cortisol (stress hormone) levels</li>
            <li><span class="dot moss"></span>Reconnect with one's body and breath</li>
          </ul>
        </div>

        <div style="display:flex;flex-direction:column;gap:16px;">
          <div class="card">
            <div class="card-icon">📵</div>
            <h4>Intentional Disconnection</h4>
            <p style="font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text-light);line-height:1.6;">Choosing to step away from screens, social media, and notifications deliberately.</p>
          </div>
          <div class="card">
            <div class="card-icon">🌱</div>
            <h4>Mindful Reconnection</h4>
            <p style="font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text-light);line-height:1.6;">Using that time for yoga, nature, creative activities, and human interaction.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ SLIDE 4 — EFFECTS OF SCREEN TIME ═══════════════ -->
  <div class="slide" id="slide-4">
    <div class="slide-num-badge">04 / 12</div>
    <div class="slide-bg">
      <div class="circle" style="width:400px;height:400px;top:-80px;right:-80px;background:radial-gradient(circle,rgba(200,80,80,0.07) 0%,transparent 70%);"></div>
    </div>
    <div class="slide-inner">
      <div class="slide-label">Health Impact</div>
      <h2 class="slide-title">Effects of <span>Excessive Screen Time</span></h2>
      <div class="divider"></div>

      <div class="cols cols-3" style="gap:20px;">
        <div class="card">
          <div class="card-icon">👁️</div>
          <h4>Eye Strain</h4>
          <ul class="bullet-list" style="margin-top:8px;">
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Digital Eye Strain (DES)</li>
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Dry & itchy eyes</li>
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Headaches & blurred vision</li>
          </ul>
        </div>
        <div class="card">
          <div class="card-icon">🌙</div>
          <h4>Poor Sleep</h4>
          <ul class="bullet-list" style="margin-top:8px;">
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Blue light suppresses melatonin</li>
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Delayed sleep onset</li>
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Disrupted sleep cycles</li>
          </ul>
        </div>
        <div class="card">
          <div class="card-icon">🧠</div>
          <h4>Mental Health</h4>
          <ul class="bullet-list" style="margin-top:8px;">
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Anxiety & depression</li>
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Reduced concentration</li>
            <li><span class="dot" style="background:#c85050;width:6px;height:6px;"></span>Short attention span (FOMO)</li>
          </ul>
        </div>
      </div>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:28px;">
        <span class="tag red">Neck & Back Pain</span>
        <span class="tag red">Social Isolation</span>
        <span class="tag red">Dopamine Dependency</span>
        <span class="tag red">Reduced Creativity</span>
        <span class="tag red">Posture Problems</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════ SLIDE 5 — ROLE OF YOGA ═══════════════ -->
  <div class="slide" id="slide-5">
    <div class="slide-num-badge">05 / 12</div>
    <div class="slide-bg">
      <div class="circle" style="width:600px;height:600px;bottom:-200px;left:-150px;"></div>
    </div>
    <div class="slide-inner">
      <div class="slide-label">The Solution</div>
      <h2 class="slide-title">Role of <span>Yoga</span> in Digital Detox</h2>
      <div class="divider"></div>

      <div class="cols cols-2" style="align-items:center;gap:48px;">
        <div>
          <ul class="bullet-list">
            <li><span class="dot moss"></span><strong>Calms the nervous system</strong> — activates parasympathetic response</li>
            <li><span class="dot moss"></span><strong>Improves focus & attention</strong> — mindful breathing rewires neural paths</li>
            <li><span class="dot moss"></span><strong>Reduces digital addiction</strong> — breaks compulsive usage patterns</li>
            <li><span class="dot moss"></span><strong>Restores mind-body connection</strong> — anchors awareness in the present</li>
            <li><span class="dot moss"></span><strong>Better sleep quality</strong> — regulates circadian rhythms naturally</li>
            <li><span class="dot moss"></span><strong>Emotional regulation</strong> — reduces anxiety and irritability</li>
          </ul>
        </div>

        <div>
          <!-- Standing pose SVG -->
          <svg viewBox="0 0 200 280" class="yoga-art" style="max-width:180px;margin:0 auto;display:block;" xmlns="http://www.w3.org/2000/svg">
            <!-- Mountain pose / Tadasana -->
            <ellipse cx="100" cy="272" rx="50" ry="6" fill="rgba(122,158,126,0.1)"/>
            <circle cx="100" cy="44" r="20" fill="#c4956a" opacity="0.85"/>
            <!-- Body -->
            <rect x="82" y="68" width="36" height="90" rx="12" fill="#7a9e7e" opacity="0.75"/>
            <!-- Arms down -->
            <rect x="60" y="70" width="18" height="80" rx="9" fill="#c4956a" opacity="0.7"/>
            <rect x="122" y="70" width="18" height="80" rx="9" fill="#c4956a" opacity="0.7"/>
            <!-- Legs -->
            <rect x="82" y="155" width="16" height="100" rx="8" fill="#5c8c4a" opacity="0.7"/>
            <rect x="102" y="155" width="16" height="100" rx="8" fill="#5c8c4a" opacity="0.7"/>
            <!-- Glow halo -->
            <circle cx="100" cy="140" r="90" fill="none" stroke="rgba(122,158,126,0.1)" stroke-width="3"/>
          </svg>
          <div style="text-align:center;margin-top:12px;">
            <span class="tag">Tadasana</span>
            <span class="tag">Grounding pose</span>
          </div>
        </div>
